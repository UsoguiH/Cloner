{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clone.saas/schemas/variant-recognition.json",
  "title": "Component variant recognition output (Phase 6.5)",
  "description": "Vision + harvest stage: groups component probes (default + pseudo-state captures) into a labeled variant tree like primary/default, primary/hover, primary/pressed, primary/disabled. Labels are AI-generated; probe IDs are referenced from the harvest.",
  "type": "object",
  "required": ["componentName", "variants"],
  "additionalProperties": false,
  "properties": {
    "componentName": { "$ref": "_shared.json#/$defs/TokenName" },
    "componentDescription": {
      "type": "string",
      "maxLength": 240,
      "description": "Optional one-sentence description of the component family."
    },
    "variants": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["variantId", "label", "probeId", "confidence"],
        "additionalProperties": false,
        "properties": {
          "variantId": {
            "type": "string",
            "enum": ["default", "hover", "focus", "active", "pressed", "disabled", "loading", "selected", "error"],
            "description": "Canonical variant slot. Constrained list to prevent label drift across runs."
          },
          "label": { "$ref": "_shared.json#/$defs/DisplayName" },
          "probeId": { "$ref": "_shared.json#/$defs/ProbeId" },
          "stateDescription": {
            "type": "string",
            "minLength": 10,
            "maxLength": 240
          },
          "rationale": { "$ref": "_shared.json#/$defs/Rationale" },
          "confidence": { "$ref": "_shared.json#/$defs/Confidence" }
        }
      }
    }
  }
}
