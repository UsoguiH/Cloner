{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clone.saas/schemas/typography-sample-copy.json",
  "title": "Typography sample copy generation output (Phase 6.7b)",
  "description": "Per type-scale step (display/headline/title/body/caption/etc.), produces a short, on-brand sample string used in the live preview's typography ladder. Sample text is generated; the type tokens themselves are referenced from the harvest.",
  "type": "object",
  "required": ["samples"],
  "additionalProperties": false,
  "properties": {
    "samples": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "items": {
        "type": "object",
        "required": ["tokenPath", "stepLabel", "sampleText", "confidence"],
        "additionalProperties": false,
        "properties": {
          "tokenPath": { "$ref": "_shared.json#/$defs/TokenPath" },
          "stepLabel": {
            "type": "string",
            "enum": [
              "display",
              "headline",
              "title",
              "subtitle",
              "body",
              "body-emphasis",
              "label",
              "caption",
              "overline",
              "code"
            ],
            "description": "Canonical type-scale step the sample illustrates."
          },
          "sampleText": {
            "type": "string",
            "minLength": 4,
            "maxLength": 120,
            "description": "On-brand sample sentence sized for the step. No emoji."
          },
          "rationale": { "$ref": "_shared.json#/$defs/Rationale" },
          "confidence": { "$ref": "_shared.json#/$defs/Confidence" }
        }
      }
    }
  }
}
